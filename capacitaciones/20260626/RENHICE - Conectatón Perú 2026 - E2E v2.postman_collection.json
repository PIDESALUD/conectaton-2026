{
  "info": {
    "_postman_id": "1d442020-fde0-4ffe-b483-7c2919e95ceb",
    "name": "RENHICE - Conectatón Perú 2026 - E2E v2",
    "description": "Flujo completo: Login Keycloak → DocumentReferences → Consent/Autorización → SHLink (QR) → IPS Bundle → Revocar → Verificar bloqueo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
